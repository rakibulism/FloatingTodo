{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Today",
  "version": "1.0.0",
  "identifier": "com.rakib.today",
  "build": {
    "frontendDist": "../../web/app"
  },
  "app": {
    "windows": [
      {
        "title": "Today",
        "width": 420,
        "height": 600,
        "minWidth": 360,
        "minHeight": 440,
        "resizable": true,
        "alwaysOnTop": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
